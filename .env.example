# Fanwan configuration — copy to .env and fill in.

# Port the API server listens on (agent + web both hit this).
SERVER_PORT=51737

# Port the Next.js web UI listens on. ASK THE USER which port to use.
WEB_PORT=51738

# Where the Next.js app reaches the API server.
# Usually http://localhost:${SERVER_PORT}
API_BASE_URL=http://localhost:51737

# SQLite database file path (absolute or relative to repo root).
DB_PATH=./data/fanwan.db

# Scheduler tick interval in milliseconds.
SCHEDULER_INTERVAL_MS=15000

# Optional: shared token required on every API request.
# When set, clients must send `Authorization: Bearer <token>` (or `?token=`).
# Leave empty for localhost-only use.
API_TOKEN=

# Timezone used by the `fa` CLI when --at is passed without a TZ designator.
# Format: ISO 8601 offset, e.g. "+08:00" (Asia/Shanghai), "-05:00", "Z" (UTC).
# Web UI and CLI display always use Asia/Shanghai unless overridden.
FANWAN_DEFAULT_TZ=+08:00
FANWAN_DISPLAY_TZ=Asia/Shanghai
